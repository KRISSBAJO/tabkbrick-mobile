{
  "expo": {
    "name": "TaskBricks",
    "slug": "taskbricks-mobile",
    "scheme": "taskbricks",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taskbricks.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.taskbricks.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F6EF"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://taskbrick-be.onrender.com/api/v1",
      "router": {},
      "eas": {
        "projectId": "4d73ef99-1612-4a52-bc76-66ab1db71bb4"
      }
    },
    "owner": "logaxp"
  }
}
