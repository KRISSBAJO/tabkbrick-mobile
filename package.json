{
  "name": "taskbricks-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:expo-go": "expo start --port 9040 --host lan --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:clear": "expo start --web --port 9040 --host localhost --clear",
    "export:web": "expo export --platform web",
    "build:ios:testflight": "eas build --platform ios --profile testflight",
    "submit:ios:testflight": "eas submit --platform ios --profile testflight --latest",
    "build:android:apk": "eas build --platform android --profile apk",
    "build:android:store": "eas build --platform android --profile production",
    "api:generate": "openapi-typescript ../taskbricks-be/docs/api/openapi.json --default-non-nullable false -o src/lib/generated/openapi.ts",
    "api:check": "npm run api:generate && git diff --exit-code -- src/lib/generated/openapi.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run api:check && npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^1.21.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "rn-emoji-keyboard": "^1.7.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "babel-preset-expo": "~54.0.11",
    "eslint": "^9.39.4",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}
